{
  "info": {
    "name": "GeoWeather API",
    "description": "Collection für die GeoWeather API - Wetter-App mit Cloud-Sync",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{BASE_URL}}/api/auth/register", "host": ["{{BASE_URL}}"], "path": ["api", "auth", "register"]},
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"user@example.com\", \"password\": \"password123\", \"name\": \"John Doe\"}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{BASE_URL}}/api/auth/login", "host": ["{{BASE_URL}}"], "path": ["api", "auth", "login"]},
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"user@example.com\", \"password\": \"password123\"}"
            }
          }
        }
      ]
    },
    {
      "name": "Favorites",
      "item": [
        {
          "name": "Create Favorite",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{TOKEN}}"}
            ],
            "url": {"raw": "{{BASE_URL}}/api/favorites", "host": ["{{BASE_URL}}"], "path": ["api", "favorites"]},
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"München\", \"latitude\": 48.1351, \"longitude\": 11.5820}"
            }
          }
        },
        {
          "name": "Get All Favorites",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{TOKEN}}"}],
            "url": {"raw": "{{BASE_URL}}/api/favorites", "host": ["{{BASE_URL}}"], "path": ["api", "favorites"]}
          }
        },
        {
          "name": "Sync Favorites",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{TOKEN}}"}
            ],
            "url": {"raw": "{{BASE_URL}}/api/favorites/sync", "host": ["{{BASE_URL}}"], "path": ["api", "favorites", "sync"]},
            "body": {
              "mode": "raw",
              "raw": "{\"favorites\": [{\"name\": \"München\", \"latitude\": 48.1351, \"longitude\": 11.5820}, {\"name\": \"Berlin\", \"latitude\": 52.5200, \"longitude\": 13.4050}]}"
            }
          }
        }
      ]
    },
    {
      "name": "Weather History",
      "item": [
        {
          "name": "Record Weather Data",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{TOKEN}}"}
            ],
            "url": {"raw": "{{BASE_URL}}/api/weather-history/record", "host": ["{{BASE_URL}}"], "path": ["api", "weather-history", "record"]},
            "body": {
              "mode": "raw",
              "raw": "{\"location\": \"München\", \"temperature\": 22.5, \"humidity\": 65, \"pressure\": 1013.25, \"windSpeed\": 5.2, \"conditions\": \"Wolkig\"}"
            }
          }
        },
        {
          "name": "Get History",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{TOKEN}}"}],
            "url": {
              "raw": "{{BASE_URL}}/api/weather-history?startDate=2024-01-01&endDate=2024-01-31",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "weather-history"],
              "query": [
                {"key": "startDate", "value": "2024-01-01"},
                {"key": "endDate", "value": "2024-01-31"}
              ]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {"key": "BASE_URL", "value": "http://localhost:3000"},
    {"key": "TOKEN", "value": ""}
  ]
}
